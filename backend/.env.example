# ─── SECURITY ───────────────────────────────────────────
# Required in both dev and prod
SECRET_KEY=

# Set to True for local dev, False for production
DEBUG=

# ─── DATABASE ───────────────────────────────────────────
# PRODUCTION (Render + Neon): set DATABASE_URL only
DATABASE_URL=

# LOCAL DEV ONLY: set these instead of DATABASE_URL
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ─── NETWORK ────────────────────────────────────────────
# Comma-separated list of allowed hosts
# Dev: localhost,127.0.0.1
# Prod: .onrender.com
DJANGO_ALLOWED_HOSTS=

# Comma-separated trusted origins for CSRF
# Dev: http://localhost:5173
# Prod: https://*.onrender.com
CSRF_TRUSTED_ORIGINS=

# Comma-separated allowed CORS origins
# Dev: http://localhost:5173
# Prod: https://your-frontend.pages.dev
CORS_ALLOWED_ORIGINS=

# ─── SERVICES ───────────────────────────────────────────
# Dev: http://localhost:8001/predict
# Prod: update when FastAPI is deployed
ML_SERVICE_URL=

# URL of the React frontend
# Dev: http://localhost:5173
# Prod: https://your-frontend.pages.dev
FRONTEND_URL=

# ─── EMAIL ───────────────────────────────────────────────
# Default: django.core.mail.backends.console.EmailBackend (prints to console)
# For production, use: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=
# SMTP settings (required for production email backend)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USE_TLS=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
# Where SIM alert notifications are sent
NOTIFICATION_EMAIL=
